{
  "name": "kaoshi-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:demo": "playwright test -c playwright.demo.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vitest run && vite build",
    "build:demo": "vue-tsc --noEmit && vitest run && vite build --mode demo && node scripts/prepare-demo-dist.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "preview:demo": "vite preview --host 0.0.0.0 --port 4174 --base /CET-4/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.10.0",
    "element-plus": "^2.10.4",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
